# ── Druid Environment Variables ────────────────────────────────────────────────
# Shared by all Druid services via docker-compose env_file

# Java options (tune heap per service; these apply globally as a baseline)
DRUID_MAXDIRECTMEMORYSIZE=6172m
DRUID_XMX=1g
DRUID_XMS=1g
DRUID_MAXNEWSIZE=250m
DRUID_NEWSIZE=250m
DRUID_LOG_LEVEL=warn

# Extensions to load
druid_extensions_loadList=["druid-histogram","druid-datasketches","druid-lookups-cached-global","postgresql-metadata-storage","druid-multi-stage-query","druid-basic-security"]

# ── Cluster networking ──────────────────────────────────────────────────────────
druid_zk_service_host=zookeeper
druid_zk_paths_base=/druid
druid_zk_service_sessionTimeoutMs=30000

# ── Metadata storage (PostgreSQL) ───────────────────────────────────────────────
druid_metadata_storage_type=postgresql
druid_metadata_storage_connector_connectURI=jdbc:postgresql://postgres:5432/druid
druid_metadata_storage_connector_user=druid
druid_metadata_storage_connector_password=druid

# ── Deep storage (local shared volume) ──────────────────────────────────────────
# For production, change to S3/GCS/Azure
druid_storage_type=local
druid_storage_storageDirectory=/opt/shared/segments

# ── Indexing / Task logs ─────────────────────────────────────────────────────────
druid_indexer_logs_type=file
druid_indexer_logs_directory=/opt/shared/indexing-logs
druid_indexer_runner_type=httpRemote

# ── Coordinator ─────────────────────────────────────────────────────────────────
druid_coordinator_balancer_strategy=cachingCost
druid_coordinator_asOverlord_enabled=false

# ── Processing ───────────────────────────────────────────────────────────────────
druid_processing_buffer_sizeBytes=536870912
druid_processing_numMergeBuffers=2
druid_processing_numThreads=2
druid_processing_tmpDir=/opt/druid/var/tmp

# ── Query cache ──────────────────────────────────────────────────────────────────
druid_cache_type=caffeine
druid_cache_sizeInBytes=512000000

# ── Security (basic auth – optional, remove to allow anonymous) ──────────────────
# To enable authentication, uncomment:
# druid_auth_authenticatorChain=["basic"]
# druid_auth_authenticator_basic_type=basic
# druid_auth_authenticator_basic_initialAdminPassword=druid1234
# druid_auth_authenticator_basic_initialInternalClientPassword=internal1234

# ── SQL ─────────────────────────────────────────────────────────────────────────
druid_sql_enable=true
druid_sql_planner_useApproximateCountDistinct=true
druid_sql_planner_useApproximateTopN=true

# ── Startup / shutdown ───────────────────────────────────────────────────────────
druid_server_http_numThreads=25
druid_emitter=noop